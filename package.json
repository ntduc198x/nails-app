{
  "name": "nails-app",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @nails/web",
    "build": "npm run build --workspace @nails/web",
    "start": "npm run start --workspace @nails/web",
    "lint": "npm run web:lint && npm run mobile:lint",
    "typecheck": "npm run web:typecheck && npm run mobile:typecheck",
    "web:dev": "npm run dev --workspace @nails/web",
    "web:build": "npm run build --workspace @nails/web",
    "web:start": "npm run start --workspace @nails/web",
    "web:lint": "npm run lint --workspace @nails/web",
    "web:typecheck": "npm run typecheck --workspace @nails/web",
    "mobile:start": "npm run start --workspace @nails/mobile",
    "mobile:go:lan": "npm run start:lan --workspace @nails/mobile",
    "mobile:go": "npm run start:tunnel --workspace @nails/mobile",
    "mobile:go:cloudflare": "npm run start:cloudflare --workspace @nails/mobile",
    "mobile:android": "npm run android --workspace @nails/mobile",
    "mobile:prebuild": "npm run prebuild:android --workspace @nails/mobile",
    "mobile:config": "npm run config --workspace @nails/mobile",
    "mobile:doctor": "npm run doctor --workspace @nails/mobile",
    "mobile:env": "node scripts/check-mobile-env.mjs",
    "mobile:ios": "npm run ios --workspace @nails/mobile",
    "mobile:lint": "npm run lint --workspace @nails/mobile",
    "mobile:typecheck": "npm run typecheck --workspace @nails/mobile"
  },
  "dependencies": {},
  "overrides": {
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {}
}
