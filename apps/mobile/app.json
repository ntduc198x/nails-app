{
  "expo": {
    "name": "Nails App",
    "slug": "nails-app-mobile",
    "scheme": "nails-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.chambeauty.nailsapp"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
