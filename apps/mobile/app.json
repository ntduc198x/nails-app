{
  "expo": {
    "name": "Nails App",
    "slug": "nails-app-mobile",
    "owner": "ntduc198x",
    "scheme": "nails-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "experiments": {
      "typedRoutes": true,
      "autolinkingModuleResolution": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chambeauty.nailsapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "package": "com.chambeauty.nailsapp",
      "runtimeVersion": "1.0.0"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cb4b6257-b4dc-479b-a3b4-abf17c518a1b"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/cb4b6257-b4dc-479b-a3b4-abf17c518a1b"
    }
  }
}
