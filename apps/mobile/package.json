{
  "name": "@nails/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "node ../../scripts/run-mobile-expo.mjs start",
    "start:lan": "node ../../scripts/run-mobile-expo.mjs start --clear --port 8082",
    "start:tunnel": "node ../../scripts/run-mobile-expo.mjs start --tunnel --clear --port 8082",
    "start:cloudflare": "node ../../scripts/run-mobile-cloudflared.mjs",
    "android": "node ../../scripts/run-mobile-expo.mjs run:android",
    "prebuild:android": "node ../../scripts/run-mobile-expo.mjs prebuild --platform android --no-install",
    "config": "node ../../scripts/run-mobile-expo.mjs config --json",
    "doctor": "npx expo-doctor",
    "ios": "node ../../scripts/run-mobile-expo.mjs run:ios",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nails/shared": "0.1.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "^54.0.33",
    "expo-constants": "~18.0.13",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.16",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.10",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  }
}
